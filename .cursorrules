  "scope_management": {
    "surgical_changes": "Modify only the exact configuration keys, scripts, or files required for the task. Do not refactor adjacent functioning systems or adjust untracked whitespace.",
    "backlog_enforcement": "If secondary technical debt, security issues, or server misconfigurations are discovered during execution, do not fix them. Document them briefly and append them to the local `ai-backlog.md` file."
